---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { getLocalizedSite } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params;
const localeCode = locale as 'zh' | 'ja' | 'en';
const siteEntries = await getCollection('site');
const editGuideEntries = await getCollection('editGuide');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const copy =
  editGuideEntries.find((entry) => entry.data.locale === localeCode)?.data ??
  editGuideEntries.find((entry) => entry.data.locale === defaultLocale)?.data;
const currentPath = '/contribute/edit';
const localeLinks = buildLocaleLinks(homeContent, localeCode, currentPath);

const alternates = supportedLocales.map((localeCode) => ({
  locale: localeCode,
  href: `/${localeCode}${currentPath}`,
}));

if (!copy) {
  throw new Error(`Missing edit guide content for locale: ${localeCode}`);
}

const docsHref = `https://github.com/LinkTh1rsty/kamitsubaki-wiki-site/blob/main/${copy.docsPath}`;

const metadata = {
  title: `${copy.title} - KAMITSUBAKI WIKI`,
  description: copy.intro,
  canonicalPath: `/${localeCode}/contribute/edit`,
  type: 'website' as const,
  noindex: true,
};
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${copy.title} - KAMITSUBAKI WIKI`} metadata={metadata}>
  <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact />

  <main class="mx-auto flex min-h-screen max-w-5xl flex-col px-4 pb-12 pt-24 sm:px-6 sm:pt-28 lg:pt-32">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4 text-[9px] font-mono uppercase tracking-[0.22em] text-white/40">
      <a href={`/${localeCode}/`} class="transition-colors hover:text-white">{copy.back}</a>
      <a href={docsHref} class="transition-colors hover:text-white" target="_blank" rel="noopener noreferrer">
        {copy.docs}
      </a>
    </div>

    <section class="border-y border-white/10 py-8 sm:py-10">
      <p class="mb-4 text-[9px] font-mono uppercase tracking-[0.28em] text-white/35">
        {copy.eyebrow}
      </p>
      <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
        <div>
          <h1 class="font-serif text-3xl font-semibold leading-tight tracking-[0.06em] text-white sm:text-5xl">
            {copy.title}
          </h1>
          <p class="mt-5 max-w-2xl text-sm leading-7 text-white/62 sm:text-base sm:leading-8">
            {copy.intro}
          </p>
        </div>
        <div class="rounded-md border border-white/10 bg-white/[0.03] p-4">
          <p class="mb-2 text-[9px] font-mono uppercase tracking-[0.2em] text-white/35">{copy.targetLabel}</p>
          <p class="break-all text-xs leading-6 text-white/70" data-edit-target-path data-invalid-target={copy.invalidTarget}>{copy.invalidTarget}</p>
        </div>
      </div>
    </section>

    <section class="grid gap-3 py-8 sm:gap-4 sm:py-10">
      {copy.steps.map((step, index) => (
        <label class="group grid cursor-pointer gap-4 rounded-md border border-white/10 bg-white/[0.025] p-4 transition-colors hover:border-white/25 sm:grid-cols-[3rem_minmax(0,1fr)_9rem] sm:items-start sm:p-5">
          <span class="font-mono text-xl text-white/30 sm:text-2xl">{String(index + 1).padStart(2, '0')}</span>
          <span>
            <span class="block text-sm font-medium tracking-[0.12em] text-white sm:text-base">{step.title}</span>
            <span class="mt-2 block text-sm leading-7 text-white/58">{step.body}</span>
          </span>
          <span class="inline-flex items-center gap-2 text-[10px] font-mono uppercase tracking-[0.18em] text-white/48 sm:justify-end">
            <input class="h-4 w-4 accent-white" type="checkbox" data-guide-step />
            {copy.checkbox}
          </span>
        </label>
      ))}
    </section>

    <section class="mt-auto flex flex-col gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs leading-6 text-white/45" data-guide-status data-locked-label={copy.locked} data-ready-label={copy.ready}>{copy.locked}</p>
      <a
        href="#"
        class="wiki-guide-action inline-flex min-h-12 items-center justify-center rounded-md border border-white/15 px-5 text-center text-[10px] font-mono uppercase tracking-[0.18em] text-white/35 transition-colors"
        aria-disabled="true"
        data-github-edit-link
      >
        {copy.ready}
      </a>
    </section>
  </main>

  <SiteFooter footer={homeContent.footer} />

  <script>
    const allowedPrefix = 'https://github.com/LinkTh1rsty/kamitsubaki-wiki-site/edit/main/src/content/';
    const params = new URLSearchParams(window.location.search);
    const target = params.get('target') || '';
    const isValidTarget = target.startsWith(allowedPrefix);
    const stepInputs = Array.from(document.querySelectorAll<HTMLInputElement>('[data-guide-step]'));
    const targetPathElement = document.querySelector('[data-edit-target-path]');
    const statusElement = document.querySelector('[data-guide-status]');
    const editLink = document.querySelector('[data-github-edit-link]');
    const invalidTarget = targetPathElement?.getAttribute('data-invalid-target') || '';
    const locked = statusElement?.getAttribute('data-locked-label') || '';
    const ready = statusElement?.getAttribute('data-ready-label') || '';
    const targetPath = isValidTarget ? target.replace(allowedPrefix, 'src/content/') : invalidTarget;

    if (targetPathElement) {
      targetPathElement.textContent = targetPath;
    }

    function syncGuideState() {
      const completed = stepInputs.every((input) => input.checked);
      const unlocked = completed && isValidTarget;

      if (!editLink || !statusElement) return;

      editLink.setAttribute('aria-disabled', String(!unlocked));
      editLink.setAttribute('href', unlocked ? target : '#');
      statusElement.textContent = unlocked ? ready : locked;
    }

    stepInputs.forEach((input) => input.addEventListener('change', syncGuideState));
    syncGuideState();
  </script>
</BaseLayout>
