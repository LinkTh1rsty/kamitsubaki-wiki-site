---
type NavItem = {
  label: string;
  href: string;
};

type LocaleLink = {
  code: string;
  label: string;
  shortLabel: string;
  href: string;
  current: boolean;
};

const { navItems, localeLinks, brandLines, homeHref = '/' } = Astro.props as {
  navItems: NavItem[];
  localeLinks: LocaleLink[];
  brandLines: string[];
  compact?: boolean;
  homeHref?: string;
};

const currentLocale = localeLinks.find((item) => item.current)?.code ?? 'en';
const themeCopy = {
  zh: {
    groupLabel: '主题模式',
    options: [
      { value: 'light', shortLabel: '日', label: '使用浅色模式' },
      { value: 'dark', shortLabel: '夜', label: '使用深色模式' },
      { value: 'system', shortLabel: '系', label: '跟随系统模式' },
    ],
  },
  ja: {
    groupLabel: 'テーマモード',
    options: [
      { value: 'light', shortLabel: '昼', label: 'ライトモードを使用' },
      { value: 'dark', shortLabel: '夜', label: 'ダークモードを使用' },
      { value: 'system', shortLabel: '自', label: 'システム設定に従う' },
    ],
  },
  en: {
    groupLabel: 'Theme mode',
    options: [
      { value: 'light', shortLabel: 'DAY', label: 'Use light mode' },
      { value: 'dark', shortLabel: 'NIGHT', label: 'Use dark mode' },
      { value: 'system', shortLabel: 'SYS', label: 'Follow system theme' },
    ],
  },
}[currentLocale] ?? {
  groupLabel: 'Theme mode',
  options: [
    { value: 'light', shortLabel: 'DAY', label: 'Use light mode' },
    { value: 'dark', shortLabel: 'NIGHT', label: 'Use dark mode' },
    { value: 'system', shortLabel: 'SYS', label: 'Follow system theme' },
  ],
};
const resolvedNavItems = navItems.map((item) => ({
  ...item,
  href: item.href.startsWith('#') ? `${homeHref}${item.href}` : item.href,
}));
---

<nav class="site-nav site-nav--compact fixed top-0 w-full z-50 mix-blend-difference flex items-center justify-between pointer-events-none px-4 py-4 md:px-8 md:py-5">
  <div class="site-nav__brand-group pointer-events-auto">
    <div
      class="site-nav__theme-switcher font-mono tracking-widest text-[8px]"
      data-theme-switcher
      role="radiogroup"
      aria-label={themeCopy.groupLabel}
    >
      {themeCopy.options.map((option) => (
        <button
          type="button"
          class="site-nav__theme-option"
          data-theme-toggle
          data-theme-value={option.value}
          role="radio"
          aria-checked="false"
          aria-label={option.label}
          title={option.label}
        >
          {option.shortLabel}
        </button>
      ))}
    </div>
    <a href={homeHref} class="site-nav__brand-link pointer-events-auto group">
      <p class="text-white tracking-kamidest font-light uppercase group-hover:opacity-50 transition-opacity duration-500 text-[9px] leading-snug md:text-[10px]">
        <span class="sm:hidden">Kamitsubaki Studio Fan Wiki</span>
        <span class="hidden sm:inline">{brandLines.join(' ')}</span>
      </p>
    </a>
  </div>
  <div class="site-nav__navigation pointer-events-auto text-[9px] md:text-[10px] tracking-kamidest-lg font-light text-white">
    <details class="site-nav__menu pointer-events-auto lg:hidden">
      <summary aria-label="Open navigation">MENU</summary>
      <div class="site-nav__menu-panel">
        {resolvedNavItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </details>
    {resolvedNavItems.map((item) => (
      <a href={item.href} class="site-nav__link hidden lg:inline hover:text-white/50 transition-all duration-300">{item.label}</a>
    ))}
    <div class="site-nav__language-switcher font-mono tracking-widest text-[8px]" aria-label="Language switcher">
      {localeLinks.map((item) => (
        <a
          href={item.href}
          aria-current={item.current ? 'page' : undefined}
          title={item.label}
          class={item.current ? 'text-white' : 'text-white/35 hover:text-white transition-colors'}
        >
          {item.shortLabel}
        </a>
      ))}
    </div>
  </div>
</nav>
